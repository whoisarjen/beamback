# Neon PostgreSQL
NUXT_DATABASE_URL="postgresql://user:pass@endpoint-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Session encryption (min 32 chars)
NUXT_SESSION_PASSWORD="at-least-32-characters-long-random-string"

# IP hashing salt
NUXT_IP_HASH_SALT="random-salt-string-for-ip-hashing"

# Google OAuth
NUXT_OAUTH_GOOGLE_CLIENT_ID=""
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=""

# Upstash Redis (rate limiting)
NUXT_UPSTASH_REDIS_URL=""
NUXT_UPSTASH_REDIS_TOKEN=""

# Public
NUXT_PUBLIC_APP_URL="http://localhost:3000"
